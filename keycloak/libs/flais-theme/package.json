{
    "name": "flais-theme",
    "version": "0.0.1",
    "description": "Flais theme for Keycloak",
    "type": "module",
    "engines": {
        "node": "25"
    },
    "scripts": {
        "dev": "vite",
        "format": "oxfmt . --write",
        "format:check": "oxfmt . --check",
        "lint": "oxlint .",
        "lint:fix": "oxlint . --fix",
        "check": "npm run lint && tsc --noEmit",
        "build": "npm run check && vite build",
        "build-keycloak-theme": "npm run build && keycloakify build",
        "storybook": "storybook dev -p 6006"
    },
    "dependencies": {
        "@tailwindcss/vite": "4.3.0",
        "keycloakify": "11.15.3",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "tailwindcss": "4.3.0"
    },
    "devDependencies": {
        "@storybook/react": "10.4.1",
        "@storybook/react-vite": "10.4.1",
        "@types/react": "19.2.15",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.4",
        "oxfmt": "^0.54.0",
        "oxlint": "1.69.0",
        "storybook": "10.4.1",
        "typescript": "5.9.3",
        "vite": "7.3.1"
    }
}